# AI Context Framework — personal context, never commit
.ai_local/

# Managed solution export — build artifact, distributed via GitHub Releases
*_managed.zip
*_unmanaged.zip

# Unmanaged solution zip — build artifact, regenerate with: pac solution pack
DoDBannerLibrary.zip

# PCF build artifacts
pcf/*/node_modules/
pcf/*/out/
pcf/*/.pcfenv/
pcf/*/bin/
pcf/*/obj/

# Power Platform solution export artifacts (auto-generated, not hand-authored)
# Controls/ — PCF bundle exported by Dataverse; source of truth is pcf/DodBannerControl/
DoDBannerLibrary/Controls/
# dvtablesearchs/ — search index metadata regenerated on every export
DoDBannerLibrary/dvtablesearchs/
# Relationships — standard system entity relationship XMLs, not our customizations
DoDBannerLibrary/Other/Relationships.xml
DoDBannerLibrary/Other/Relationships/