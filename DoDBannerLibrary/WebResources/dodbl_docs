    <div class="card doc-section" id="classification-levels">
      <div class="card-header"><span class="card-header-icon">&#x1F3A8;</span><div><div class="card-title">Classification Levels</div><div class="card-subtitle">Supported data-classification values and banner colors</div></div></div>
      <div class="card-body" style="padding:0">
        <table class="classif-table">
          <thead><tr><th>data-classification value</th><th>Banner</th><th>Hex</th><th>CSS match</th></tr></thead>
          <tbody>
            <tr><td><code>CUI</code> &mdash; any value starting with <code>CU</code></td><td><span class="swatch" style="background:#5a04b0">CUI</span></td><td><code>#5a04b0</code></td><td><code>^=&quot;CU&quot;</code></td></tr>
            <tr><td><code>U</code> &mdash; any value starting with <code>U</code></td><td><span class="swatch" style="background:#5cb85c">UNCLASSIFIED</span></td><td><code>#5cb85c</code></td><td><code>^=&quot;U&quot;</code></td></tr>
