// DoD Banner Library — Model-Driven App Form Script
// Schema: dodbl_dodbanner  |  Version: 1.1.0
//
// Usage:
//   1. Add this web resource as a form library on the target entity form.
//   2. Register an OnLoad event handler:
//        Function: DoDBannerLibrary.DodBanner.onFormLoad
//        Pass execution context: Yes
//
// The script reads four environment variables:
//   dodbl_BannerEnabled     — Boolean  — set to false/no to suppress the banner
//   dodbl_BannerType        — String   — "DoD" (consent modal) or "CUI" (CSS mark only)
//   dodbl_ConsentExpiryDays — Number   — cookie lifetime in days (default 30)
//   dodbl_DoDConsentText    — String   — AO-approved text; falls back to built-in default
//
// Falls back to built-in defaults if any variable is absent or the API call fails.

/* global Xrm */
"use strict";

var DoDBannerLibrary = DoDBannerLibrary || {};

DoDBannerLibrary.DodBanner = (function () {

  // ── Defaults ────────────────────────────────────────────────────────────────

  var BANNER_TYPE_DEFAULT  = "DoD";
  var EXPIRY_DAYS_DEFAULT  = 30;
  var CONSENT_TEXT_DEFAULT =
    "WARNING: This is a U.S. Government computer system, which may be accessed " +
    "and used only for authorized Government business by authorized personnel. " +
    "Unauthorized access or use of this computer system may subject violators to " +
    "criminal, civil, and/or administrative action. All information on this system " +
    "may be intercepted, recorded, read, copied, and disclosed by and to authorized " +
    "personnel for official purposes, including criminal investigations. Such " +
    "information includes sensitive data encrypted to comply with confidentiality " +
    "and privacy requirements. Access or use of this computer system by any person, " +
    "whether authorized or unauthorized, constitutes consent to these terms. " +
    "There is no right of privacy in this system.";

  // ── Cookie helpers ───────────────────────────────────────────────────────────

  function setCookie(name, value, days) {
    var expiry = new Date();
    expiry.setTime(expiry.getTime() + days * 24 * 60 * 60 * 1000);
    document.cookie =
      name + "=" + value +
      ";expires=" + expiry.toUTCString() +
      ";path=/;SameSite=Lax";
  }

  function getCookie(name) {
    var prefix = name + "=";
    var parts = decodeURIComponent(document.cookie).split(";");
    for (var i = 0; i < parts.length; i++) {
      var c = parts[i].trimStart();
      if (c.indexOf(prefix) === 0) return c.substring(prefix.length);
    }
    return "";
  }

  // ── DOM helpers ──────────────────────────────────────────────────────────────

  function injectCSS() {
    if (document.querySelector("style[data-dodbl-core]")) return;
    // Inline the consent modal CSS — MDA form iframes do not reliably load
    // external web resource stylesheets via <link>, so we embed the styles
    // directly. banner-core.css remains the source of truth for Power Pages.
    var css = [
      "@media only screen and (max-device-width:480px){",
      "#cookieConsent{background:#f6f6f6;min-height:26px;min-width:90%;",
      "font-size:14px;color:black;line-height:26px;padding:10px 15px;",
      "font-family:\"Trebuchet MS\",Helvetica,sans-serif;",
      "position:fixed;top:50%;left:50%;transform:translate(-50%,-25%);",
      "display:none;z-index:9998;border-color:black;border-style:ridge;",
      "max-height:calc(100% - 26px);overflow-y:auto;}}",
      "@media (min-width:481px) and (max-width:759px){",
      "#cookieConsent{background:#f6f6f6;min-height:26px;min-width:80%;",
      "font-size:14px;color:black;line-height:26px;padding:10px 15px;",
      "font-family:\"Trebuchet MS\",Helvetica,sans-serif;",
      "position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);",
      "display:none;z-index:9998;border-color:black;border-style:ridge;",
      "max-height:calc(100% - 26px);overflow-y:auto;}}",
      "@media (min-width:760px){",
      "#cookieConsent{background:#f6f6f6;min-height:26px;",
      "font-size:14px;color:black;line-height:26px;padding:10px 15px;",
      "font-family:\"Trebuchet MS\",Helvetica,sans-serif;",
      "position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);",
      "display:none;z-index:9998;border-color:black;border-style:ridge;",
      "max-height:calc(100% - 26px);overflow-y:auto;}}",
      "#cookieConsent a{color:#4b8ee7;text-decoration:none;}",
      "#closeCookieConsent{float:right;}",
      "#closeCookieConsent:hover{color:#fff;}",
      "#cookieConsent a.cookieConsentOK{background-color:#f1d600;color:#000;",
      "border-radius:5px;padding:0 20px;cursor:pointer;float:right;margin:0 60px 0 10px;}",
      "#cookieConsent a.cookieConsentOK:hover{background-color:#e0c91f;}",
      ".consentBackground{position:fixed;display:none;top:0;left:0;",
      "width:100%;height:100%;background-color:#fff;opacity:.8;z-index:9997;}"
    ].join("");
    var style = document.createElement("style");
    style.setAttribute("data-dodbl-core", "1");
    style.textContent = css;
    document.head.appendChild(style);
  }

  function injectModal(consentText) {
    if (document.getElementById("cookieConsent")) return;

    var text = (consentText && consentText.trim()) ? consentText : CONSENT_TEXT_DEFAULT;

    // Build DOM nodes directly — avoids any innerHTML XSS risk on the consent text.
    // All structural styles are applied as inline properties rather than relying on
    // the injected <style> tag, which is blocked by MDA GCC High nonce-based CSP.
    var closeBtn = document.createElement("a");
    closeBtn.id = "closeCookieConsent";
    closeBtn.textContent = "\u2715";
    closeBtn.style.float          = "right";
    closeBtn.style.cursor         = "pointer";
    closeBtn.style.textDecoration = "none";
    closeBtn.style.color          = "inherit";

    var p = document.createElement("p");
    p.textContent    = text;
    p.style.margin   = "0 0 10px 0";
    p.style.overflow = "auto";

    var okBtn = document.createElement("a");
    okBtn.className              = "cookieConsentOK";
    okBtn.textContent            = "I Acknowledge";
    okBtn.style.backgroundColor  = "#f1d600";
    okBtn.style.color            = "#000";
    okBtn.style.borderRadius     = "5px";
    okBtn.style.padding          = "0 20px";
    okBtn.style.cursor           = "pointer";
    okBtn.style.float            = "right";
    okBtn.style.margin           = "0 60px 0 10px";
    okBtn.style.textDecoration   = "none";
    okBtn.style.lineHeight       = "26px";
    okBtn.style.display          = "inline-block";

    var modal = document.createElement("div");
    modal.id                  = "cookieConsent";
    modal.style.background    = "#f6f6f6";
    modal.style.fontSize      = "14px";
    modal.style.color         = "black";
    modal.style.lineHeight    = "26px";
    modal.style.padding       = "10px 15px";
    modal.style.fontFamily    = '"Trebuchet MS", Helvetica, sans-serif';
    modal.style.position      = "fixed";
    modal.style.top           = "50%";
    modal.style.left          = "50%";
    modal.style.transform     = "translate(-50%, -50%)";
    modal.style.display       = "none";
    modal.style.zIndex        = "9998";
    modal.style.borderColor   = "black";
    modal.style.borderStyle   = "ridge";
    modal.style.maxHeight     = "calc(100% - 26px)";
    modal.style.overflowY     = "auto";
    modal.style.boxSizing     = "border-box";
    modal.style.width         = "80%";
    modal.style.maxWidth      = "600px";
    modal.style.minWidth      = "280px";
    modal.appendChild(closeBtn);
    modal.appendChild(p);
    modal.appendChild(okBtn);

    var overlay = document.createElement("div");
    overlay.className                = "consentBackground";
    overlay.style.position           = "fixed";
    overlay.style.display            = "none";
    overlay.style.top                = "0";
    overlay.style.left               = "0";
    overlay.style.width              = "100%";
    overlay.style.height             = "100%";
    overlay.style.backgroundColor    = "#fff";
    overlay.style.opacity            = "0.8";
    overlay.style.zIndex             = "9997";

    var root = document.createElement("div");
    root.setAttribute("data-dodbl-root", "1");
    root.appendChild(modal);
    root.appendChild(overlay);

    document.body.appendChild(root);
  }

  function fadeIn(el, duration) {
    el.style.opacity = "0";
    el.style.display = "block";
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / duration, 1);
      el.style.opacity = String(p);
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function fadeOut(el, duration) {
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / duration, 1);
      el.style.opacity = String(1 - p);
      if (p < 1) {
        requestAnimationFrame(step);
      } else {
        el.style.display = "none";
        el.style.opacity = "";
      }
    }
    requestAnimationFrame(step);
  }

  function showBanner(expiryDays) {
    if (getCookie("Accepted") !== "") return;
    var modal = document.getElementById("cookieConsent");
    var bg    = document.querySelector(".consentBackground");
    if (!modal || !bg) return;

    setTimeout(function () {
      fadeIn(modal, 200);
      bg.style.display = "block";
    }, 800);

    document.querySelectorAll("#closeCookieConsent, .cookieConsentOK").forEach(function (el) {
      el.addEventListener("click", function () {
        setCookie("Accepted", "Yes", expiryDays);
        fadeOut(modal, 200);
        bg.style.display = "none";
      });
    });
  }

  // ── Classification bar helpers ───────────────────────────────────────────────

  function getClassificationColor(bannerType) {
    var t = (bannerType || "").toUpperCase();
    if (t.indexOf("CU") === 0) return "#5a04b0";  // CUI → purple
    if (t.indexOf("U")  === 0) return "#5cb85c";  // UNCLASSIFIED → green
    if (t.indexOf("CO") === 0) return "#286090";  // CONFIDENTIAL → blue
    if (t.indexOf("S")  === 0) return "#d9534f";  // SECRET → red
    if (t.indexOf("T")  === 0) return "#f0ad4e";  // TOP SECRET → orange
    return "#5e5e5e";                             // unknown → grey
  }

  function injectClassificationBar(bannerType) {
    // Idempotent — remove any existing bar before (re-)rendering
    var existing = document.querySelector("[data-dodbl-bar]");
    if (existing && existing.parentNode) existing.parentNode.removeChild(existing);

    var bar = document.createElement("div");
    bar.setAttribute("data-dodbl-bar", "1");
    bar.textContent = bannerType.toUpperCase();
    bar.style.position       = "fixed";
    bar.style.top            = "0";
    bar.style.left           = "0";
    bar.style.width          = "100%";
    bar.style.height         = "28px";
    bar.style.backgroundColor = getClassificationColor(bannerType);
    bar.style.color          = "#fff";
    bar.style.fontWeight     = "bold";
    bar.style.fontFamily     = '"Segoe UI",Tahoma,Geneva,Verdana,sans-serif';
    bar.style.fontSize       = "14px";
    bar.style.display        = "flex";
    bar.style.alignItems     = "center";
    bar.style.justifyContent = "center";
    bar.style.letterSpacing  = "0.06em";
    bar.style.textShadow     = "1px 1px 0 rgba(0,0,0,.3)";
    bar.style.zIndex         = "9999";
    bar.style.boxSizing      = "border-box";
    document.body.insertBefore(bar, document.body.firstChild);
  }

  // ── Environment variable reader ──────────────────────────────────────────────
  //
  // Two-step approach: fetch definitions (for schema + default), then fetch
  // per-environment values and overlay. Returns a plain {schemaname: value} map.

  function getEnvVars() {
    var schemas = [
      "dodbl_BannerEnabled",
      "dodbl_BannerType",
      "dodbl_ConsentExpiryDays",
      "dodbl_DoDConsentText"
    ];
    var schemaFilter = schemas
      .map(function (s) { return "schemaname eq '" + s + "'"; })
      .join(" or ");

    return Xrm.WebApi.retrieveMultipleRecords(
      "environmentvariabledefinition",
      "?$select=environmentvariabledefinitionid,schemaname,defaultvalue&$filter=" + schemaFilter
    ).then(function (defResult) {
      var defMap = {};
      defResult.entities.forEach(function (def) {
        defMap[def.environmentvariabledefinitionid] = {
          schemaname:   def.schemaname,
          resolvedValue: def.defaultvalue
        };
      });

      var defIds = Object.keys(defMap);
      if (defIds.length === 0) return {};

      var valFilter = defIds
        .map(function (id) { return "_environmentvariabledefinitionid_value eq " + id; })
        .join(" or ");

      return Xrm.WebApi.retrieveMultipleRecords(
        "environmentvariablevalue",
        "?$select=value,_environmentvariabledefinitionid_value&$filter=" + valFilter
      ).then(function (valResult) {
        // Per-environment values override the definition defaults
        valResult.entities.forEach(function (val) {
          var defId = val["_environmentvariabledefinitionid_value"];
          if (defMap[defId]) defMap[defId].resolvedValue = val.value;
        });

        var vars = {};
        Object.keys(defMap).forEach(function (id) {
          vars[defMap[id].schemaname] = defMap[id].resolvedValue;
        });
        return vars;
      });
    });
  }

  // ── Public API ───────────────────────────────────────────────────────────────

  function onFormLoad(executionContext) {
    getEnvVars()
      .then(function (vars) {
        var enabled = String(vars["dodbl_BannerEnabled"] || "yes").toLowerCase();
        if (enabled === "no" || enabled === "false") return;

        var bannerType  = ((vars["dodbl_BannerType"] || BANNER_TYPE_DEFAULT) + "").trim();
        var expiryDays  = parseInt(vars["dodbl_ConsentExpiryDays"] || EXPIRY_DAYS_DEFAULT, 10);
        if (isNaN(expiryDays) || expiryDays < 0) expiryDays = EXPIRY_DAYS_DEFAULT;
        var consentText = vars["dodbl_DoDConsentText"] || "";

        injectCSS();

        if (bannerType === "DoD") {
          injectModal(consentText);
          showBanner(expiryDays);
        } else {
          injectClassificationBar(bannerType);
        }
      })
      .catch(function () {
        // Env vars unavailable — show banner with built-in defaults
        injectCSS();
        injectModal("");
        showBanner(EXPIRY_DAYS_DEFAULT);
      });
  }

  return { onFormLoad: onFormLoad };

})();
