<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DoD Banner Library — Home</title>
  <style>
    :root {
      --primary:       #1b3a6b;
      --primary-light: #e8edf5;
      --accent:        #f1d600;
      --accent-hover:  #e0c91f;
      --bg:            #f3f2f1;
      --surface:       #ffffff;
      --border:        #edebe9;
      --text:          #323130;
      --text-sec:      #605e5c;
      --text-dis:      #a19f9d;
      --radius:        4px;
      --shadow:        0 1.6px 3.6px rgba(0,0,0,.13), 0 .3px .9px rgba(0,0,0,.11);
      --shadow-lg:     0 8px 32px rgba(0,0,0,.22), 0 2px 8px rgba(0,0,0,.14);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; font-size: 14px; line-height: 1.6; color: var(--text); background: var(--bg); min-height: 100vh; }

    /* ── Consent overlay ──────────────────────────────────────────── */
    #consentOverlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(10, 20, 40, 0.96);
      z-index: 9999;
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
    }
    #consentCard {
      background: #fff;
      max-width: 700px; width: 100%;
      border: 2px solid #555;
      border-radius: 6px;
      box-shadow: var(--shadow-lg);
      padding: 36px 40px 32px;
    }
    .consent-header {
      display: flex; align-items: center; gap: 14px;
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 2px solid var(--border);
    }
    .consent-icon  { font-size: 32px; flex-shrink: 0; }
    .consent-title { font-size: 16px; font-weight: 700; color: var(--primary); }
    .consent-sub   { font-size: 12px; color: var(--text-sec); margin-top: 2px; }
    #consentCard p {
      font-size: 13px; color: #222; line-height: 1.75; margin-bottom: 24px;
    }
    .consent-footer {
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .consent-note { font-size: 11px; color: var(--text-dis); max-width: 360px; }
    #consentBtn {
      display: inline-block; background: var(--accent); color: #000;
      font-weight: 700; font-size: 13px; padding: 9px 32px;
      border-radius: var(--radius); border: none; cursor: pointer;
      white-space: nowrap; user-select: none; flex-shrink: 0;
      transition: background .15s;
    }
    #consentBtn:hover { background: var(--accent-hover); }

    /* ── Home content ─────────────────────────────────────────────── */
    #homeContent { display: none; }
    .app-header {
      background: var(--primary); color: #fff;
      padding: 18px 32px; display: flex; align-items: center; gap: 16px;
    }
    .app-header-icon {
      width: 40px; height: 40px; background: rgba(255,255,255,.18);
      border-radius: var(--radius); display: flex; align-items: center;
      justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .app-header h1 { font-size: 18px; font-weight: 600; }
    .app-header p  { font-size: 12px; opacity: .85; margin-top: 2px; }
    .app-header-badge {
      margin-left: auto; background: rgba(255,255,255,.2); color: #fff;
      font-size: 11px; font-weight: 600; padding: 3px 11px;
      border-radius: 10px; white-space: nowrap;
    }
    .main { max-width: 860px; margin: 0 auto; padding: 28px 32px 48px; }

    /* ── Security notice ──────────────────────────────────────────── */
    .security-notice {
      display: flex; align-items: flex-start; gap: 14px;
      background: #fff8e1; border: 1px solid #fde7a0;
      border-left: 4px solid var(--accent);
      border-radius: var(--radius); padding: 14px 18px;
      margin-bottom: 24px; font-size: 12px; color: #4d3700;
    }
    .security-notice-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    .security-notice strong { display: block; margin-bottom: 3px; font-size: 13px; }

    /* ── Nav tiles ────────────────────────────────────────────────── */
    .section-label {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .07em; color: var(--text-dis); margin-bottom: 14px;
    }
    .tiles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 14px; margin-bottom: 28px;
    }
    .tile {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); box-shadow: var(--shadow);
      padding: 20px 18px; cursor: pointer;
      transition: box-shadow .15s, border-color .15s, background .15s;
      display: flex; flex-direction: column; gap: 10px;
      user-select: none;
    }
    .tile:hover { border-color: var(--primary); background: var(--primary-light); box-shadow: 0 3px 8px rgba(0,0,0,.14); }
    .tile-icon  { font-size: 26px; }
    .tile-title { font-size: 13px; font-weight: 600; color: var(--text); }
    .tile-desc  { font-size: 11px; color: var(--text-sec); line-height: 1.5; }

    /* ── Status card ──────────────────────────────────────────────── */
    .status-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); }
    .status-card-hdr { padding: 12px 18px; border-bottom: 1px solid var(--border); font-size: 11px; font-weight: 700; color: var(--text-sec); text-transform: uppercase; letter-spacing: .06em; }
    .status-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 18px; border-bottom: 1px solid var(--border); font-size: 12px; }
    .status-row:last-child { border-bottom: none; }
    .status-lbl { color: var(--text-sec); }
    .status-val { font-weight: 600; font-family: 'Cascadia Code','Consolas',monospace; font-size: 11px; }
    .badge-green { background: #dff6dd; color: #0e5a0e; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 700; }
    .badge-warn  { background: #fde7a0; color: #4d3700;  padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 700; }
  </style>
</head>
<body>

<!-- ── Consent overlay ──────────────────────────────────────────────────── -->
<div id="consentOverlay">
  <div id="consentCard">
    <div class="consent-header">
      <div class="consent-icon">🛡️</div>
      <div>
        <div class="consent-title">U.S. Government System &mdash; Consent Required</div>
        <div class="consent-sub">DoD Banner Library Management &middot; GCC High IL4/IL5 &middot; Authorized Users Only</div>
      </div>
    </div>
    <p>WARNING: This is a U.S. Government computer system, which may be accessed and used only for authorized Government business by authorized personnel. Unauthorized access or use of this computer system may subject violators to criminal, civil, and/or administrative action. All information on this system may be intercepted, recorded, read, copied, and disclosed by and to authorized personnel for official purposes, including criminal investigations. Such information includes sensitive data encrypted to comply with confidentiality and privacy requirements. Access or use of this computer system by any person, whether authorized or unauthorized, constitutes consent to these terms. There is no right of privacy in this system.</p>
    <div class="consent-footer">
      <span class="consent-note">By clicking <strong>I Acknowledge</strong> you confirm you have read and accept these terms. Your acknowledgement is required before accessing this system.</span>
      <button id="consentBtn" type="button">I Acknowledge</button>
    </div>
  </div>
</div>

<!-- ── Home content ─────────────────────────────────────────────────────── -->
<div id="homeContent">

  <div class="app-header">
    <div class="app-header-icon">🛡️</div>
    <div>
      <h1>DoD Banner Library</h1>
      <p>Management App &mdash; GCC High / IL4/IL5</p>
    </div>
    <span class="app-header-badge">v1.3.0</span>
  </div>

  <div class="main">

    <div class="security-notice">
      <div class="security-notice-icon">⚠️</div>
      <div>
        <strong>U.S. Government System &mdash; Authorized Use Only</strong>
        This is a DoD information system. Your use constitutes consent to monitoring and recording. All activity may be disclosed for official purposes. There is no right of privacy in this system.
      </div>
    </div>

    <p class="section-label">Quick Navigation</p>
    <div class="tiles-grid">
      <div class="tile" onclick="navTo('webresource','dodbl_docs')">
        <div class="tile-icon">📋</div>
        <div class="tile-title">Documentation</div>
        <div class="tile-desc">Post-import checklist, setup guides, and component reference.</div>
      </div>
      <div class="tile" onclick="navTo('webresource','dodbl_release-notes')">
        <div class="tile-icon">📝</div>
        <div class="tile-title">Release Notes</div>
        <div class="tile-desc">Version history and changelog for all releases.</div>
      </div>
      <div class="tile" onclick="navTo('webresource','dodbl_webtemplatesource')">
        <div class="tile-icon">🌐</div>
        <div class="tile-title">Web Template Source</div>
        <div class="tile-desc">Liquid markup for Power Pages Web Template deployment.</div>
      </div>
      <div class="tile" onclick="navTo('custom','dodbl_canvasappdemo_bb4ae')">
        <div class="tile-icon">🎨</div>
        <div class="tile-title">Canvas App Demo</div>
        <div class="tile-desc">Interactive demo of the DodBannerControl PCF component.</div>
      </div>
    </div>

    <p class="section-label">Solution Status</p>
    <div class="status-card">
      <div class="status-card-hdr">DoDBannerLibrary &mdash; GFIM-DEV</div>
      <div class="status-row"><span class="status-lbl">Solution Version</span><span class="status-val">1.3.0.0</span></div>
      <div class="status-row"><span class="status-lbl">Publisher Prefix</span><span class="status-val">dodbl_</span></div>
      <div class="status-row"><span class="status-lbl">Cloud</span><span class="status-val">GCC High &middot; IL4/IL5</span></div>
      <div class="status-row"><span class="status-lbl">PCF Control</span><span class="status-val">DoDBannerLibrary.DodBannerControl v1.2.0 &nbsp;<span class="badge-green">Active</span></span></div>
      <div class="status-row"><span class="status-lbl">Consent Cookie</span><span class="status-val" id="cookieStatus">Checking&hellip;</span></div>
    </div>

  </div>
</div>

<script>
"use strict";

// ── Document target ──────────────────────────────────────────────────────────
// Use window.top.document so the consent cookie is shared with dodbl_dodbanner.js
// which also reads window.top.document.cookie from inside the form iframe.
var _doc;
try { _doc = (window.top && window.top.document) ? window.top.document : document; }
catch (_e) { _doc = document; }

// ── Cookie helpers ───────────────────────────────────────────────────────────
var COOKIE_NAME  = "Accepted";
var EXPIRY_DAYS  = 30;

function setCookie(name, value, days) {
  try {
    var exp = new Date();
    exp.setTime(exp.getTime() + days * 24 * 60 * 60 * 1000);
    _doc.cookie = name + "=" + value + ";expires=" + exp.toUTCString() + ";path=/;SameSite=Lax";
  } catch (_e) { /* cross-origin guard */ }
}

function getCookie(name) {
  try {
    var prefix = name + "=";
    var parts  = _doc.cookie.split(";");       // split BEFORE decoding — guards URIError
    for (var i = 0; i < parts.length; i++) {
      var c = parts[i].trimStart();
      if (c.indexOf(prefix) === 0) {
        try { return decodeURIComponent(c.substring(prefix.length)); }
        catch (_e) { return c.substring(prefix.length); }
      }
    }
  } catch (_e) { /* cookie access blocked */ }
  return "";
}

// ── Navigation ───────────────────────────────────────────────────────────────
function navTo(type, name) {
  try {
    if (type === "webresource") {
      parent.Xrm.Navigation.navigateTo(
        { pageType: "webresource", webresourceName: name },
        { target: 1 }
      );
    } else if (type === "custom") {
      parent.Xrm.Navigation.navigateTo(
        { pageType: "custom", name: name },
        { target: 1 }
      );
    }
  } catch (_e) { /* Xrm unavailable — standalone view, no-op */ }
}

// ── Belt-and-suspenders: addGlobalNotification ───────────────────────────────
// Called alongside the overlay. Ensures consent is enforced at the UCI shell
// level even if the user navigates away from the home page iframe before clicking
// the overlay button.
var _notifId = null;

function addGlobalNotif(text) {
  try {
    parent.Xrm.App.addGlobalNotification({
      type: 2, level: 3, message: text,
      showCloseButton: false,
      action: { actionLabel: "I Acknowledge", eventHandler: function () { onAcknowledge(false); } }
    }).then(
      function (id) { _notifId = id; },
      function ()   { /* API unavailable */ }
    );
  } catch (_e) { /* parent.Xrm unavailable */ }
}

function clearGlobalNotif() {
  if (!_notifId) return;
  try { parent.Xrm.App.clearGlobalNotification(_notifId); _notifId = null; }
  catch (_e) { /* ignore */ }
}

// ── Acknowledge ───────────────────────────────────────────────────────────────
function onAcknowledge(fromOverlay) {
  setCookie(COOKIE_NAME, "Yes", EXPIRY_DAYS);
  clearGlobalNotif();
  if (fromOverlay) {
    var overlay = document.getElementById("consentOverlay");
    var home    = document.getElementById("homeContent");
    home.style.display = "block";
    var start = null;
    requestAnimationFrame(function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / 250, 1);
      overlay.style.opacity = String(1 - p);
      if (p < 1) { requestAnimationFrame(step); }
      else        { overlay.style.display = "none"; }
    });
  }
  updateCookieStatus();
}

// ── Cookie status indicator ───────────────────────────────────────────────────
function updateCookieStatus() {
  var el = document.getElementById("cookieStatus");
  if (!el) return;
  if (getCookie(COOKIE_NAME) === "Yes") {
    el.innerHTML = 'Acknowledged &nbsp;<span class="badge-green">Active</span>';
  } else {
    el.innerHTML = 'Not set &nbsp;<span class="badge-warn">Pending</span>';
  }
}

// ── Init ─────────────────────────────────────────────────────────────────────
(function init() {
  var CONSENT_TEXT =
    "WARNING: This is a U.S. Government computer system, which may be accessed " +
    "and used only for authorized Government business by authorized personnel. " +
    "Unauthorized access or use of this computer system may subject violators to " +
    "criminal, civil, and/or administrative action. All information on this system " +
    "may be intercepted, recorded, read, copied, and disclosed by and to authorized " +
    "personnel for official purposes, including criminal investigations. Such " +
    "information includes sensitive data encrypted to comply with confidentiality " +
    "and privacy requirements. Access or use of this computer system by any person, " +
    "whether authorized or unauthorized, constitutes consent to these terms. " +
    "There is no right of privacy in this system.";

  if (getCookie(COOKIE_NAME) === "Yes") {
    // Cookie already set — skip overlay, show home directly
    document.getElementById("consentOverlay").style.display = "none";
    document.getElementById("homeContent").style.display    = "block";
  } else {
    // Show overlay AND fire belt-and-suspenders global notification
    addGlobalNotif(CONSENT_TEXT);
    document.getElementById("consentBtn").addEventListener("click", function () {
      onAcknowledge(true);
    });
  }

  updateCookieStatus();
}());
</script>
</body>
</html>